# Mango named launcher entries.
# Used by:
#   mango-run <name>

# Core applications
terminal:$HOME/.config/mango/scripts/APPS/terminal.sh
browser:$HOME/.config/mango/scripts/APPS/browser.sh
filemanager:$HOME/.config/mango/scripts/APPS/filemanager.sh
youtube:$HOME/.config/mango/scripts/APPS/youtube.sh

# Gaming
steam:$HOME/.config/mango/scripts/APPS/steam.sh
gaming:$HOME/.config/mango/scripts/APPS/steam.sh

# Emulation
samcoupe:$HOME/.config/mango/scripts/APPS/samcoupe.sh
speccynext:$HOME/.config/mango/scripts/APPS/speccynext.sh

# System helpers
update-system:$HOME/.config/mango/scripts/update-system

# Diagnostics
mango-check:$HOME/.config/mango/scripts/mango-check
repo-check:$HOME/.config/mango/scripts/repo-check
