#!/usr/bin/env bash
# Run named Mango helper commands from settings.file.

set -euo pipefail

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
MANGO_DIR="${MANGO_DIR:-$CONFIG_HOME/mango}"
SETTINGS_FILE="${MANGO_SETTINGS_FILE:-$MANGO_DIR/settings.file}"

export PATH="$MANGO_DIR/scripts:$MANGO_DIR/scripts/APPS:$PATH"

usage() {
  echo "Usage: mango-run <name> [args...]" >&2
  echo >&2
  echo "Available entries:" >&2
  if [[ -f "$SETTINGS_FILE" ]]; then
    awk -F: '
      /^[[:space:]]*#/ { next }
      /^[[:space:]]*$/ { next }
      NF >= 2 { print "  " $1 }
    ' "$SETTINGS_FILE" >&2
  fi
}

if (( $# < 1 )); then
  usage
  exit 1
fi

name="$1"
shift

if [[ ! -f "$SETTINGS_FILE" ]]; then
  echo "ERROR: settings file not found: $SETTINGS_FILE" >&2
  exit 1
fi

cmd="$(
  awk -F: -v key="$name" '
    $1 == key {
      sub(/^[^:]*:/, "")
      print
      found=1
      exit
    }
    END {
      if (!found) exit 1
    }
  ' "$SETTINGS_FILE"
)" || {
  echo "ERROR: unknown mango-run entry: $name" >&2
  usage
  exit 1
}

if [[ -z "$cmd" ]]; then
  echo "ERROR: empty command for mango-run entry: $name" >&2
  exit 1
fi

exec bash -lc "$cmd" -- "$@"
