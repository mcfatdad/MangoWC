#!/usr/bin/env bash
# Stable MangoWM all-window floating toggle.
#
# This intentionally does not move, resize, scatter, or reorder windows.
# Mango can toggle all visible windows between tiled and floating, but it does
# not reliably preserve exact tiled positions for 3+ windows after manual moves.

set -euo pipefail

MMSG="${MMSG_BIN:-mmsg}"

if ! command -v "$MMSG" >/dev/null 2>&1; then
  notify-send "Mango" "mmsg not found" 2>/dev/null || true
  exit 1
fi

"$MMSG" dispatch toggle_all_floating >/dev/null 2>&1 || {
  notify-send "Mango" "toggle_all_floating failed" 2>/dev/null || true
  exit 1
}
